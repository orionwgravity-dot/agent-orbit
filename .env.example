# ============================================================
# CONFIGURACIÓN DEL AGENTE WhatsApp AI
# ============================================================
# Copia este fichero a .env.local y completa los valores.
# Las variables marcadas como Obligatorias deben tener valor
# para que el bot arranque.
# ============================================================

# ----------------------------------------------------------
# OBLIGATORIAS — el bot aborta al arrancar (exit 1) si faltan
# ----------------------------------------------------------

# API key de OpenRouter (formato: sk-or-v1-...)
# La obtienes en: https://openrouter.ai/keys
# MODELOS RECOMENDADOS (NO usar :free — están saturados y dan 429 en producción):
#   - openai/gpt-4o-mini      (default, rápido y económico)
#   - anthropic/claude-haiku-4-5
#   - google/gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# API key de Groq para transcripción de audios (formato: gsk_...)
# La obtienes gratis en: https://console.groq.com/keys
GROQ_API_KEY=

# ----------------------------------------------------------
# HERRAMIENTAS OPCIONALES — si están vacías, la tool asociada
# devuelve ok:false y el modelo reacciona sin romper el flujo
# ----------------------------------------------------------

# Webhook de Google Apps Script para guardar leads en Sheets.
# Si no lo tienes, la tool guardarLead queda inactiva.
# Tutorial: https://oriongravity.com/docs/google-sheets-webhook
GOOGLE_SHEETS_WEBHOOK_URL=

# URL de Cal.com o Calendly para agendar llamadas.
# Ejemplo: https://cal.com/tu-usuario/diagnostico
# Si no la tienes, la tool agendar queda inactiva.
CAL_BOOKING_URL=

# ----------------------------------------------------------
# PRODUCCIÓN (solo necesario si vas a desplegar)
# ----------------------------------------------------------

# Clave secreta para los tokens JWT de autenticación
# Cámbiala por un valor aleatorio largo en producción
JWT_SECRET=cambia-esta-clave-por-algo-aleatorio-y-largo

# Puerto del dashboard Next.js (default: 3000)
PORT=3000

# Nivel del logger del bot: silent|error|warn|info|debug
# El logger interno de Baileys va siempre en silent
LOG_LEVEL=info